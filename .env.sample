# Copy to .env and fill in, or let `azd up` generate these values for you.
# Local runs authenticate with Azure AD (DefaultAzureCredential), so run `az login` first.

# Required: your Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Optional: admin API key. Leave empty to use Azure AD (recommended).
AZURE_SEARCH_API_KEY=

# Base name for indexes. The tooling creates <base>-baseline and <base>-tuned.
SEARCH_INDEX_BASE=kb

# Content language for the linguistic layer (analyzer + speller). Default nl (Dutch).
CONTENT_LANGUAGE=nl

# Name of the semantic configuration created on the tuned index.
SEMANTIC_CONFIG_NAME=default-semantic

# Optional vector/hybrid module. Off by default.
ENABLE_VECTOR=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
