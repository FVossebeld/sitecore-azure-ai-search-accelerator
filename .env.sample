# Copy to .env and fill in, or let `azd up` generate these values for you.
# Local runs authenticate with Azure AD (DefaultAzureCredential), so run `az login` first.

# Required: your Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Optional: admin API key. Leave empty to use Azure AD (recommended).
AZURE_SEARCH_API_KEY=

# Base name for indexes. The tooling creates <base>-baseline and <base>-tuned.
SEARCH_INDEX_BASE=kb

# Content language for the linguistic layer (analyzer + synonyms). Default nl (Dutch).
CONTENT_LANGUAGE=nl

# Name of the semantic configuration created on the tuned index.
SEMANTIC_CONFIG_NAME=default-semantic

# Sitecore Experience Edge export (headless). Used by src/ingest/export_edge.py.
# Leave empty if you produce the canonical export another way.
SITECORE_EDGE_ENDPOINT=https://edge.sitecorecloud.io/api/graphql/v1
SITECORE_EDGE_API_KEY=
SITECORE_SITE_ROOT_ID=
SITECORE_LANGUAGE=nl-NL
SITECORE_BASE_URL=
SITECORE_TEMPLATES=
SITECORE_TITLE_FIELD=Title
SITECORE_BODY_FIELDS=Content
SITECORE_TAGS_FIELD=

# Optional vector/hybrid module. Off by default.
ENABLE_VECTOR=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536
